<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground  –  108 × 108 dp
  Safe zone: centre 66 dp circle (radius 33, centred at 54,54).
  Design: bold "W" + accent dot for the "i".
  All path points verified inside the safe-zone circle.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Bold W  (x 31–77, y 35–73, arm width ≈ 8 dp)
      Polygon traced clockwise from top-left outer corner:
        outer outline → inner outline → close
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
          M 31,35
          L 43,73
          L 49,57
          L 54,66
          L 59,57
          L 65,73
          L 77,35
          L 69,35
          L 60,61
          L 54,52
          L 48,61
          L 39,35
          Z" />

    <!-- Accent dot — represents the lowercase "i" in "WiI" -->
    <path
        android:fillColor="#82B1FF"
        android:pathData="M 82,47 m -4,0 a 4,4 0 1,0 8,0 a 4,4 0 1,0 -8,0 Z" />

</vector>
